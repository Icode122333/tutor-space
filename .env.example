# Copy to .env for local dev. Set these in Vercel → Environment Variables for production.

# ── Site (card return URL + payment callbacks) ─────────────────────────────
SITE_URL=https://dataplusacademy.com
# Optional override for card return only (defaults to SITE_URL)
# XENTRIPAY_CARD_RETURN_URL_BASE=https://dataplusacademy.com

# ── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── XentriPay v2 (production) ──────────────────────────────────────────────
# Keys: https://xentripay.com/settings/api-keys
XENTRIPAY_API_KEY=
XENTRIPAY_SANDBOX=false
XENTRIPAY_BASE_URL=https://xentripay.com
XENTRIPAY_CHARGES_INCLUDED=true
# Dashboard webhooks are URL-only; leave empty unless XentriPay sends a secret header.
# XENTRIPAY_WEBHOOK_SECRET=

# ── XentriPay v2 (local sandbox) ─────────────────────────────────────────────
# XENTRIPAY_SANDBOX=true
# XENTRIPAY_BASE_URL=https://test.xentripay.com

# ── Pricing ──────────────────────────────────────────────────────────────────
USD_TO_RWF_RATE=1463.5

# ── LMBTech (optional second gateway) ───────────────────────────────────────
LMBTECH_ENABLED=false
LMBTECH_APP_KEY=
LMBTECH_SECRET_KEY=

# ── DB migrations only (never commit real values) ───────────────────────────
# DATABASE_URL=postgresql://postgres:...@db....supabase.co:5432/postgres
